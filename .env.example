# Frontend runtime/build config
#
# Default is empty, which makes the app call relative /api paths.
# That is the intended S3 + CloudFront setup:
#   CloudFront default behavior -> S3 frontend
#   CloudFront /api/* behavior  -> ALB Ingress
#
# For local npm run dev without Docker Compose backend ports, you can either
# leave this empty and configure a Vite proxy later, or set service-specific URLs.

VITE_API_BASE_URL=

# Optional local overrides. These are useful only for local development.
VITE_USER_SERVICE_URL=http://localhost:8001
VITE_PRODUCT_SERVICE_URL=http://localhost:8002
VITE_ORDER_SERVICE_URL=http://localhost:8003
